{
  "manifest_version": 3,

  "name": "Festember Downloader",
  "description": "Official comment export tool for Festember Fantasy Football.",

  "version": "1.0",

  "permissions": ["activeTab"],

  "host_permissions": ["https://www.instagram.com/*"],

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}
